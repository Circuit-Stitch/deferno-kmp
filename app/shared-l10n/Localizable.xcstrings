    "breakdown_unavailable_body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on an inference engine in Settings → Agent to break a stuck task into smaller steps."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa un motor de inferencia en Configuración → Agente para desglosar una tarea estancada en pasos más pequeños."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
