    "settings_legal_account_removal_email_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hello,\n\nI'd like to request removal of my Deferno account and its associated data.\n\nAccount email:\n\nThank you."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hola:\n\nQuisiera solicitar la eliminación de mi cuenta de Deferno y sus datos asociados.\n\nCorreo de la cuenta:\n\nGracias."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hallo,\n\nich möchte die Löschung meines Deferno-Kontos und der zugehörigen Daten beantragen.\n\nKonto-E-Mail:\n\nVielen Dank."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नमस्ते,\n\nमैं अपने Deferno खाते और उससे जुड़े डेटा को हटाने का अनुरोध करना चाहता/चाहती हूँ।\n\nखाते का ईमेल:\n\nधन्यवाद।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Olá,\n\nGostaria de solicitar a remoção da minha conta do Deferno e dos dados associados a ela.\n\nE-mail da conta:\n\nAgradeço."
          }
        }
      }
    },
