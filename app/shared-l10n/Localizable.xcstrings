    "settings_storage_recordings_description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recordings you kept when accepting a brain dump. Tap one to open its task — or the Inbox if it's still to review."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Grabaciones que guardaste al aceptar una descarga mental. Toca una para abrir su tarea — o la Bandeja de entrada si aún está por revisar."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aufnahmen, die du beim Annehmen eines Braindumps behalten hast. Tipp auf eine, um ihre Aufgabe zu öffnen — oder den Eingang, wenn sie noch zur Durchsicht ist."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वे रिकॉर्डिंग जो आपने मन की बात स्वीकारते समय रखी थीं। किसी एक पर टैप करके उसका कार्य खोलें — या इनबॉक्स, अगर वह अभी समीक्षा में है।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Gravações que você manteve ao aceitar um despejo de ideias. Toque em uma para abrir a tarefa — ou a Caixa de entrada se ainda estiver para revisar."
          }
        }
      }
    },
