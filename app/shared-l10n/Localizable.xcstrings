    "settings_data_export_import_description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Export your tasks and lists as a backup file you can save or share — or import one to restore them."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporta tus tareas y listas como un archivo de respaldo que puedes guardar o compartir — o importa uno para restaurarlas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportiere deine Aufgaben und Listen als Sicherungsdatei, die du speichern oder teilen kannst — oder importiere eine, um sie wiederherzustellen."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने कार्यों और सूचियों को बैकअप फ़ाइल के रूप में एक्सपोर्ट करें जिसे आप सेव या शेयर कर सकते हैं — या उन्हें बहाल करने के लिए कोई फ़ाइल इंपोर्ट करें।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporte suas tarefas e listas como um arquivo de backup que você pode salvar ou compartilhar — ou importe um para restaurá-las."
          }
        }
      }
    },
