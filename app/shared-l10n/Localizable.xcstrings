    "profile_sign_out_reassure_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your tasks stay safe in Deferno. You can sign back in with your token anytime."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus tareas quedan a salvo en Deferno. Puedes volver a iniciar sesión con tu token cuando quieras."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Aufgaben bleiben sicher in Deferno. Du kannst dich jederzeit mit deinem Token wieder anmelden."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके कार्य Deferno में सुरक्षित रहते हैं। आप कभी भी अपने token से फिर साइन इन कर सकते हैं।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Suas tarefas ficam seguras no Deferno. Você pode entrar de novo com seu token quando quiser."
          }
        }
      }
    },
    "profile_token_refresh_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your token needs a refresh. Sign in again to continue."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu token necesita renovarse. Inicia sesión de nuevo para continuar."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Token muss erneuert werden. Melde dich noch einmal an, um fortzufahren."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके token को रीफ़्रेश की ज़रूरत है। जारी रखने के लिए फिर से साइन इन करें।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu token precisa ser renovado. Entre de novo para continuar."
          }
        }
      }
    },
    "profile_unavailable_reassure_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Check your connection and try again — nothing was lost."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisa tu conexión e inténtalo de nuevo — no se perdió nada."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prüf deine Verbindung und versuch es noch einmal — nichts ist verloren gegangen."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपना कनेक्शन जाँचें और फिर से कोशिश करें — कुछ भी खोया नहीं है।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifique sua conexão e tente de novo — nada foi perdido."
          }
        }
      }
    },
