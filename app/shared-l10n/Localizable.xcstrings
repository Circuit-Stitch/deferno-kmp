    "assistant_empty_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I can find things, make changes, and help you plan."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedo encontrar cosas, hacer cambios y ayudarte a planificar."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich kann Dinge finden, Änderungen machen und dir beim Planen helfen."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मैं चीज़ें ढूँढ सकता हूँ, बदलाव कर सकता हूँ और योजना बनाने में मदद कर सकता हूँ।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Posso encontrar coisas, fazer mudanças e ajudar você a planejar."
          }
        }
      }
    },
