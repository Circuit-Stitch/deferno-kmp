    "braindump_idle_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap to record. We'll sort what you say into your Inbox."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca para grabar. Ordenaremos lo que digas en tu Bandeja de entrada."
