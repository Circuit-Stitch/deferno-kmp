    "settings_notify_braindump_description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get a notification when your drafts are ready to review — tapping it opens the Inbox."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recibe una notificación cuando tus borradores estén listos para revisar — al tocarla se abre la Bandeja de entrada."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erhalte eine Benachrichtigung, wenn deine Entwürfe zur Durchsicht bereit sind — ein Tipp darauf öffnet den Eingang."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब आपके ड्राफ़्ट समीक्षा के लिए तैयार हों तो सूचना पाएँ — उस पर टैप करने से इनबॉक्स खुलता है।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Receba uma notificação quando seus rascunhos estiverem prontos para revisar — tocar nela abre a Caixa de entrada."
          }
        }
      }
    },
    "settings_notify_braindump_label": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Notify me when a brain dump is ready"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Avísame cuando una descarga mental esté lista"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Benachrichtige mich, wenn ein Braindump fertig ist"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मन की बात तैयार होने पर मुझे सूचित करें"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Avise quando um despejo de ideias estiver pronto"
          }
        }
      }
    },
    "settings_permissions_intro": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manage Deferno's notifications, storage, and other permissions in your device settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gestiona las notificaciones, el almacenamiento y otros permisos de Deferno en la configuración de tu dispositivo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwalte Benachrichtigungen, Speicher und weitere Berechtigungen von Deferno in den Einstellungen deines Geräts."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Deferno की सूचनाएँ, स्टोरेज और अन्य अनुमतियाँ अपने डिवाइस की सेटिंग्स में प्रबंधित करें।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerencie notificações, armazenamento e outras permissões do Deferno nas configurações do dispositivo."
          }
        }
      }
    },
