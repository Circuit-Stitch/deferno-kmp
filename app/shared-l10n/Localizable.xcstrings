      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Broke it into %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La dividí en %@."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich habe es in %@ zerlegt."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इसे %@ में बाँट दिया।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Dividi em %@."
          }
        }
      }
    },
    "breakdown_msg_classifier_retry": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I couldn't quite work that out on-device. Want to say it a different way?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No logré entenderlo bien en el dispositivo. ¿Quieres decirlo de otra forma?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das konnte ich auf dem Gerät nicht ganz einordnen. Magst du es anders formulieren?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मैं इसे डिवाइस पर ठीक से समझ नहीं पाया। क्या आप इसे किसी और तरीक़े से कहना चाहेंगे?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não consegui entender direito aqui no dispositivo. Quer dizer de outro jeito?"
          }
        }
      }
    },
    "breakdown_msg_confirm_drop": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sounds like you keep putting it off. Do you actually need this? I can take “%@” off your list — just say yes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Parece que lo sigues posponiendo. ¿De verdad necesitas esto? Puedo quitar «%@» de tu lista — solo di que sí."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Klingt, als würdest du es immer wieder aufschieben. Brauchst du das wirklich? Ich kann „%@“ von deiner Liste nehmen — sag einfach Ja."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "लगता है आप इसे टालते आ रहे हैं। क्या यह सच में ज़रूरी है? मैं “%@” को आपकी सूची से हटा सकता हूँ — बस हाँ कह दें।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Parece que você vem adiando isso. Você realmente precisa disso? Posso tirar “%@” da sua lista — é só dizer sim."
          }
        }
      }
    },
    "breakdown_msg_dropped": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Done — taking “%@” off your list. You can recover it from history."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Listo — quito «%@» de tu lista. Puedes recuperarla desde el historial."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alles klar — ich nehme „%@“ von deiner Liste. Über den Verlauf kannst du es wiederherstellen."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हो गया — “%@” को आपकी सूची से हटा रहा हूँ। आप इसे इतिहास से वापस पा सकते हैं।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pronto — tirando “%@” da sua lista. Dá para recuperar pelo histórico."
          }
        }
      }
    },
    "breakdown_msg_finished_dropped": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All set — we cleared what you didn't need."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo listo — quitamos lo que no necesitabas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geschafft — wir haben ausgeräumt, was du nicht mehr brauchst."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सब हो गया — जो आपको ज़रूरी नहीं था, वह हमने हटा दिया।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Tudo certo — tiramos o que você não precisava."
          }
        }
      }
    },
    "breakdown_msg_finished_ready": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Everything's broken down and ready. Nice work."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo está desglosado y listo. Buen trabajo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alles ist zerlegt und startklar. Gut gemacht."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सब कुछ बँटकर तैयार है। बहुत बढ़िया।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Tudo dividido e pronto. Bom trabalho."
          }
        }
      }
    },
    "breakdown_msg_kept_reask": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kept it. So — what's stopping you from “%@”?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La conservamos. Entonces, ¿qué te impide avanzar con «%@»?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Behalten. Also — was hält dich bei „%@“ auf?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रख लिया। तो — “%@” में आपको क्या रोक रहा है?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantido. Então — o que está te impedindo de “%@”?"
          }
        }
      }
    },
    "breakdown_msg_more_urgent": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Something more pressing right now — noted. (Lowering its priority is coming soon; for now it stays put.)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hay algo más urgente ahora mismo — anotado. (Pronto podrás bajar su prioridad; por ahora se queda donde está.)"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerade drängt etwas anderes — notiert. (Die Priorität zu senken kommt bald; bis dahin bleibt es, wo es ist.)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अभी कुछ और ज़्यादा ज़रूरी है — नोट कर लिया। (इसकी प्राथमिकता घटाना जल्द आ रहा है; फ़िलहाल यह यहीं रहेगा।)"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Algo mais urgente agora — anotado. (Baixar a prioridade está a caminho; por enquanto, fica como está.)"
          }
        }
      }
    },
    "breakdown_msg_name_first_piece": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Let's name the first small piece — what's one part you could start on?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nombremos la primera pieza pequeña: ¿con qué parte podrías empezar?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lass uns das erste kleine Stück benennen — was wäre ein Teil, mit dem du anfangen könntest?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आइए पहला छोटा हिस्सा तय करें — कौन-सा एक हिस्सा है जिससे आप शुरुआत कर सकते हैं?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Vamos nomear o primeiro pedacinho — qual parte você poderia começar?"
          }
        }
      }
    },
    "breakdown_msg_ready_to_go": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Then “%@” is ready to go."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Entonces «%@» está lista para empezar."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dann ist „%@“ startklar."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "तो फिर “%@” तैयार है।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Então “%@” está pronto para começar."
          }
        }
      }
    },
    "breakdown_msg_transient_obstacle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That's temporary — it's okay to skip it for now. It still mattered to you, so it'll be here when you're ready."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eso es temporal — está bien dejarlo pasar por ahora. Te seguía importando, así que aquí estará cuando quieras retomarlo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das ist nur vorübergehend — es ist okay, es erst mal zu überspringen. Es war dir wichtig, also bleibt es hier, bis du bereit bist."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह अस्थायी है — अभी इसे छोड़ देना ठीक है। यह आपके लिए मायने रखता था, इसलिए जब आप तैयार हों, यह यहीं मिलेगा।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso é temporário — tudo bem pular por enquanto. Continua importante para você, então vai estar aqui quando você quiser retomar."
          }
        }
      }
    },
    "breakdown_msg_waiting_dependency": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sounds like it's blocked by something else — noted. (Linking that blocker is coming soon.)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Parece que está bloqueado por otra cosa — anotado. (Pronto podrás vincular ese bloqueo.)"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Klingt, als würde etwas anderes es blockieren — notiert. (Diesen Blocker zu verknüpfen kommt bald.)"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "लगता है यह किसी और चीज़ की वजह से रुका है — नोट कर लिया। (उस अड़चन को जोड़ना जल्द आ रहा है।)"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Parece que está bloqueado por outra coisa — anotado. (Vincular esse bloqueio está a caminho.)"
          }
        }
      }
    },
    "breakdown_msg_whats_stopping": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What's stopping you from “%@”?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Qué te impide avanzar con «%@»?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Was hält dich bei „%@“ auf?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@” में आपको क्या रोक रहा है?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O que está te impedindo de “%@”?"
          }
        }
      }
    },
    "breakdown_needs_ai_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on Apple Intelligence in Settings to break a stuck task into smaller steps, all on-device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa Apple Intelligence en Configuración para dividir una tarea atascada en pasos más pequeños, todo en el dispositivo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalte Apple Intelligence in den Einstellungen ein, um eine festgefahrene Aufgabe in kleinere Schritte zu zerlegen — alles auf dem Gerät."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी अटके कार्य को छोटे चरणों में बाँटने के लिए सेटिंग्स में Apple Intelligence चालू करें — सब कुछ डिवाइस पर ही।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative a Apple Intelligence nos Ajustes para dividir uma tarefa travada em passos menores, tudo no dispositivo."
          }
        }
      }
    },
    "breakdown_needs_ai_title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Breakdown needs Apple Intelligence"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La división necesita Apple Intelligence"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aufschlüsseln braucht Apple Intelligence"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ब्रेकडाउन के लिए Apple Intelligence चाहिए"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O detalhamento precisa da Apple Intelligence"
          }
        }
      }
    },
    "breakdown_prereq_define_done": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Define what “done” looks like, and decide if I'm the right person or should delegate"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Definir cómo se ve «terminado» y decidir si soy la persona indicada o debería delegar"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Festlegen, wie „fertig“ aussieht, und entscheiden, ob ich es selbst mache oder abgebe"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "तय करें कि “पूरा हुआ” कैसा दिखेगा, और सोचें कि यह मुझे करना चाहिए या किसी और को सौंपना चाहिए"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Definir o que significa “pronto” e decidir se eu sou a pessoa certa ou se devo delegar"
          }
        }
      }
    },
    "breakdown_prereq_figure_out": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Figure out how to do this"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Averiguar cómo hacer esto"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Herausfinden, wie das geht"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "समझें कि इसे कैसे करना है"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Descobrir como fazer isso"
          }
        }
      }
    },
