    "inbox_empty_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Brain-dump drafts land here for you to review. Speak a brain dump and Deferno turns it into draft tasks for this list."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los borradores de tus descargas mentales llegan aquí para que los revises. Di una descarga mental y Deferno la convertirá en borradores de tareas para esta lista."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Braindump-Entwürfe landen hier zur Durchsicht. Sprich einen Braindump ein und Deferno macht daraus Aufgaben-Entwürfe für diese Liste."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मन की बात के ड्राफ़्ट यहाँ आते हैं ताकि आप उनकी समीक्षा कर सकें। मन की बात बोलें और Deferno उसे इस सूची के लिए ड्राफ़्ट कार्यों में बदल देगा।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Os rascunhos do despejo de ideias chegam aqui para você revisar. Fale um despejo de ideias e o Deferno o transforma em rascunhos de tarefas para esta lista."
          }
        }
      }
    },
