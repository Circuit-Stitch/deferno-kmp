    "inbox_footer_reassurance": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Triage at your pace — nothing's lost."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisa a tu ritmo — nada se pierde."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sortiere in deinem Tempo — nichts geht verloren."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपनी रफ़्तार से निपटाएँ — कुछ भी खोता नहीं।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Organize no seu ritmo — nada se perde."
          }
        }
      }
    },
    "inbox_header_subtitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Review each one — add it as a task, or dismiss it. Nothing's deleted."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisa cada uno — agrégalo como tarea o descártalo. Nada se elimina."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sieh dir jeden an — füg ihn als Aufgabe hinzu oder verwirf ihn. Nichts wird gelöscht."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हर एक की समीक्षा करें — उसे कार्य के रूप में जोड़ें, या ख़ारिज करें। कुछ भी हटाया नहीं जाता।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Revise um por um — adicione como tarefa ou dispense. Nada é excluído."
          }
        }
      }
    },
