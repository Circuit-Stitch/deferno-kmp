    "settings_storage_ios_note": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "New attachments are kept on this device. Other providers are coming later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los adjuntos nuevos se guardan en este dispositivo. Más proveedores llegarán más adelante."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Neue Anhänge bleiben auf diesem Gerät. Weitere Anbieter kommen später."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नए अटैचमेंट इसी डिवाइस पर रखे जाते हैं। अन्य प्रदाता बाद में आएँगे।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Novos anexos ficam neste dispositivo. Outros provedores chegam depois."
          }
        }
      }
    },
    "settings_storage_keep_recordings_description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save the original voice recording on this device when you accept a brain dump, so you can listen back later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda la grabación de voz original en este dispositivo cuando aceptas una descarga mental, para que puedas escucharla después."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beim Annehmen eines Braindumps die Original-Sprachaufnahme auf diesem Gerät speichern, damit du sie später anhören kannst."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मन की बात स्वीकार करने पर मूल आवाज़ की रिकॉर्डिंग इसी डिवाइस पर सेव करें, ताकि आप बाद में उसे सुन सकें।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Salve a gravação de voz original neste dispositivo quando você aceitar um despejo de ideias, para ouvir de novo mais tarde."
          }
        }
      }
    },
    "settings_storage_keep_recordings_label": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep brain dump recordings"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conservar grabaciones de descargas mentales"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Braindump-Aufnahmen behalten"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मन की बात की रिकॉर्डिंग रखें"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
