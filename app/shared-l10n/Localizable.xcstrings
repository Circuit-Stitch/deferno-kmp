    "settings_speech_none_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dictation uses an on-device speech engine. There isn't one available on this device yet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El dictado usa un motor de voz en el dispositivo. Aún no hay ninguno disponible en este dispositivo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diktieren nutzt eine Sprach-Engine auf dem Gerät. Auf diesem Gerät ist noch keine verfügbar."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बोलकर लिखना डिवाइस पर मौजूद स्पीच इंजन से चलता है। इस डिवाइस पर अभी कोई उपलब्ध नहीं है।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O ditado usa um mecanismo de fala no dispositivo. Ainda não há um disponível neste dispositivo."
          }
        }
      }
    },
    "settings_storage_all_items_description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Find the items with the largest attachments, across everything — searched on this device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Encuentra los elementos con los adjuntos más grandes, en todo — buscado en este dispositivo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Finde die Elemente mit den größten Anhängen, über alles hinweg — gesucht auf diesem Gerät."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सबसे बड़े अटैचमेंट वाले आइटम खोजें, हर जगह से — खोज इसी डिवाइस पर होती है।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Encontre os itens com os maiores anexos, em tudo — busca feita neste dispositivo."
          }
        }
      }
    },
    "settings_storage_all_items_section": {
      "localizations": {
