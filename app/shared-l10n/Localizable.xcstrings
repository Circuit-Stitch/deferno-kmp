    "assistant_error_stream_dropped": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The connection dropped before the reply finished."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La conexión se cortó antes de terminar la respuesta."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Verbindung brach ab, bevor die Antwort fertig war."
          }
