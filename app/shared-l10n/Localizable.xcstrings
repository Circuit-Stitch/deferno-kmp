          "stringUnit": {
            "state": "translated",
            "value": "रिकॉर्ड करने के लिए टैप करें। आप जो कहेंगे उसे हम आपके इनबॉक्स में डाल देंगे।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque para gravar. Vamos organizar o que você disser na sua Caixa de entrada."
