<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!-- Merged into the generated Info.plist (GENERATE_INFOPLIST_FILE stays YES; explicit keys win).
     Holds only what the INFOPLIST_KEY_* build settings can't express: the custom URL scheme the
     OAuth redirect re-enters the app on (ADR-0026) — IosBrowserAuthenticator's fixed
     `com.circuitstitch.deferno://auth` redirect URI, forwarded by DefernoApp.onOpenURL. -->
<dict>
	<!-- Dev-only: substituted from the DEV_STAGING_TOKEN build setting (Local.xcconfig ← Secrets.xcconfig,
	     both Debug-only). Empty in Release / CI / a fresh clone, so DefernoRoot seeds no dev account there. -->
	<key>DevStagingToken</key>
	<string>$(DEV_STAGING_TOKEN)</string>
	<!-- The backend environment, injected per Xcode build configuration via the DEFERNO_ENV build
	     setting (ADR-0047). DefernoApp reads this and maps it to DefernoEnvironment, decoupling the
	     env from the debug/release build type. -->
	<key>DefernoEnv</key>
	<string>$(DEFERNO_ENV)</string>
	<!-- The Brain dump recorder + New-form dictation capture the mic (ADR-0027/#92). -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Deferno uses the microphone to capture a brain dump or dictate a task by voice.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Deferno transcribes your voice on-device to turn a brain dump into tasks.</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.circuitstitch.deferno.auth-redirect</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.circuitstitch.deferno</string>
			</array>
		</dict>
	</array>
	<!-- Brain dump background durability (#270): the BGProcessingTask backstop that finishes a take whose
	     in-app grace window expired while backgrounded. The id must match BRAIN_DUMP_BG_TASK_ID. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>processing</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.circuitstitch.deferno.braindump.process</string>
	</array>
</dict>
</plist>
