# SQLCipher for the iOS encrypted per-Account database (ADR-0009, #21).
#
# The shared Kotlin static `Deferno.framework` opens the DB via SQLiter (`native-driver`) with an
# `Encryption(key=…)` config that applies the key through `PRAGMA key` — so the app must link a SQLite
# build that understands it. SQLCipher (CommonCrypto provider) supplies the standard `sqlite3_*` symbols
# the framework references *plus* real at-rest encryption. We link **only** SQLCipher (the app target's
# `OTHER_LDFLAGS` carries no `-lsqlite3`), so there is exactly one sqlite implementation and no duplicate
# symbols. `linkSqlite` is effectively false already — the cinterop's system-sqlite linker opt is not
# propagated into the consuming app, so SQLCipher cleanly satisfies the undefined symbols.
#
# After `pod install`, build via the generated `iosApp.xcworkspace` (not the `.xcodeproj`).
platform :ios, '16.0'

# Custom build configuration (ADR-0047): `prodDebug` is a NEW Xcode configuration named "ProdDebug" — a
# Production-backed, debuggable, distinctly-bundled dogfood install that coexists with prodRelease
# (Release) and stagingDebug (Debug). CocoaPods only knows Debug/Release by default and maps any unknown
# configuration to :release; tell it ProdDebug builds like Debug so SQLCipher compiles with the same
# (debug) settings and lands in the ProdDebug build dir the app links against. Run `pod install` after
# changing this (Debug/Release auto-map, so only the non-standard config is listed).
project 'iosApp', 'ProdDebug' => :debug

target 'iosApp' do
  # :inhibit_warnings — sqlite3.c (the SQLite amalgamation SQLCipher vendors) emits ~117
  # -Wshorten-64-to-32 warnings under Xcode's default warning set. They're intentional, safe
  # truncations in upstream SQLite (lengths are bounded by SQLITE_MAX_LENGTH, which fits an int),
  # not our code — silence them for this pod only so they don't drown the build log.
  pod 'SQLCipher', '~> 4.6', :inhibit_warnings => true
end
