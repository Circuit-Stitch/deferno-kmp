<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup and device-transfer rules for API 31+.
  https://developer.android.com/guide/topics/data/autobackup
-->
<data-extraction-rules>
    <cloud-backup>
        <!--
          Secure-storage vault: a device-bound cache excluded from OS backup (ADR-0009) — its
          AndroidKeyStore key is non-exportable, so a restored device re-authenticates rather
          than carrying the token across. Keep the path in sync with
          AndroidKeystoreSecretVault.DEFAULT_PREFS_NAME ("deferno_secure_vault").
        -->
        <exclude domain="sharedpref" path="deferno_secure_vault.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="deferno_secure_vault.xml"/>
    </device-transfer>
</data-extraction-rules>
