<?xml version="1.0" encoding="utf-8"?>
<!--
  Legacy (API <= 30) auto-backup rules.
  https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <!--
      The secure-storage vault (core/secure: AndroidKeystoreSecretVault) is a device-bound
      cache, NOT backed up (ADR-0009): its AES key is non-exportable in the AndroidKeyStore,
      so restored ciphertext is undecryptable and a new device re-authenticates. Keep this
      path in sync with AndroidKeystoreSecretVault.DEFAULT_PREFS_NAME ("deferno_secure_vault").
    -->
    <exclude domain="sharedpref" path="deferno_secure_vault.xml"/>
    <!--
      Per-Account database keys (core/database: AndroidDatabaseKeyProvider) and the account roster
      (core/data: SharedPreferencesAccountRegistry) are device-bound caches, NOT backed up
      (ADR-0009): the DB keys' AES wrapping key is non-exportable, and a restored device
      re-authenticates + re-syncs rather than carrying ciphertext / orphaned accounts across. Keep
      these paths in sync with AndroidDatabaseKeyProvider / SharedPreferencesAccountRegistry prefs.
    -->
    <exclude domain="sharedpref" path="deferno_db_keys.xml"/>
    <exclude domain="sharedpref" path="deferno_account_roster.xml"/>
</full-backup-content>
