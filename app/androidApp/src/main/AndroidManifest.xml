<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- On-device Dictation (#92, ADR-0018): microphone capture for the New surface's speech-to-text.
         Runtime-requested on first mic tap; audio is recognized on-device and never leaves the device. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Android platform on-device speech engine (#93, ADR-0018): package visibility for the system
         RecognitionService, required on Android 11+ for SpeechRecognizer / isOnDeviceRecognitionAvailable
         to resolve it. On-device recognizer only — audio never leaves the device. -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <!-- Connectivity monitoring (#158): the default-network callback behind the reconnect-triggered
         outbox flush + the online-only create gate (normal permission, granted at install). -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Brain dump async drafts (#150, ADR-0027): the BrainDumpWorker posts a "drafts ready" notification
         when on-device transcription + extraction finish (recording is foreground in the overlay, so no
         FOREGROUND_SERVICE_MICROPHONE is needed). Runtime-requested on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Koog AARs over-declare minSdk 35 (ADR-0027, #147): their convention plugin sets a blanket
         `minSdk = 35` on every Android artifact, but the modules core/agent consumes hold NO
         android.*/androidx.* API at all (verified against the 1.0.0 tag — their androidMain sets are
         plain-Kotlin actuals), so the declaration is packaging, not an API floor, and overriding it
         is safe down to this app's minSdk 27. The list is every ai.koog AAR on the runtime classpath
         (namespace = artifact name dotted); a Koog bump that adds an artifact fails the manifest
         merge loudly with the exact name to append. -->
    <uses-sdk tools:overrideLibrary="ai.koog.agents.tools, ai.koog.agents.utils,
        ai.koog.http.client.core, ai.koog.http.client.ktor,
        ai.koog.prompt.executor.anthropic.client, ai.koog.prompt.executor.clients,
        ai.koog.prompt.executor.model, ai.koog.prompt.llm, ai.koog.prompt.markdown,
        ai.koog.prompt.model, ai.koog.prompt.structure, ai.koog.serialization.core,
        ai.koog.utils" />

    <application
        android:name=".DefernoApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Deferno"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Deferno.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- OAuth redirect capture (#15, ADR-0026): the system browser returns to the app at
                 com.circuitstitch.deferno://auth after sign-in; onNewIntent forwards it to the
                 AuthRedirectInbox the in-flight BrowserAuthenticator awaits. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.circuitstitch.deferno" android:host="auth" />
            </intent-filter>
            <!-- Google Assistant App Actions deep-links (ADR-0036, #248/#249): the BIIs declared in
                 res/xml/shortcuts.xml open these URIs. `…://plan` foregrounds the Plan Destination;
                 `…://create?title=<slot>` creates a verbatim Task offline-first. Distinct hosts from the
                 OAuth `auth` filter above (same custom scheme). MainActivity.routeAppActionsDeepLink
                 routes them through the RootComponent (signed-out → Auth shell). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.circuitstitch.deferno" android:host="plan" />
                <data android:scheme="com.circuitstitch.deferno" android:host="create" />
            </intent-filter>
            <!-- App Actions capability inventory (ADR-0036): binds the open-Plan / create-Task BIIs to the
                 deep-links above so Google Assistant can invoke them. -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>
    </application>

</manifest>
