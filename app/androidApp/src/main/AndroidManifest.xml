<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- On-device Dictation (#92, ADR-0018): microphone capture for the New surface's speech-to-text.
         Runtime-requested on first mic tap; audio is recognized on-device and never leaves the device. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:name=".DefernoApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Deferno"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Deferno">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- OAuth redirect capture (#15, ADR-0026): the system browser returns to the app at
                 com.circuitstitch.deferno://auth after sign-in; onNewIntent forwards it to the
                 AuthRedirectInbox the in-flight BrowserAuthenticator awaits. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.circuitstitch.deferno" android:host="auth" />
            </intent-filter>
        </activity>
    </application>

</manifest>
