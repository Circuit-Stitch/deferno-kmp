        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalte unter Einstellungen → Agent eine Inferenz-Engine ein, um eine festgefahrene Aufgabe in kleinere Schritte zu zerlegen."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी अटके हुए कार्य को छोटे चरणों में बाँटने के लिए सेटिंग्स → एजेंट में कोई AI इंजन चालू करें।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
