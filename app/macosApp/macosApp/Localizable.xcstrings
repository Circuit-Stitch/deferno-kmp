    "breakdown_msg_classifier_retry": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I couldn't quite work that out on-device. Want to say it a different way?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No logré entenderlo bien en el dispositivo. ¿Quieres decirlo de otra forma?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das konnte ich auf dem Gerät nicht ganz einordnen. Magst du es anders formulieren?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मैं इसे डिवाइस पर ठीक से समझ नहीं पाया। क्या आप इसे किसी और तरीक़े से कहना चाहेंगे?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não consegui entender direito aqui no dispositivo. Quer dizer de outro jeito?"
          }
        }
      }
    },
    "breakdown_msg_dropped": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Done — taking “%@” off your list. You can recover it from history."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Listo — quito «%@» de tu lista. Puedes recuperarla desde el historial."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alles klar — ich nehme „%@“ von deiner Liste. Über den Verlauf kannst du es wiederherstellen."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हो गया — “%@” को आपकी सूची से हटा रहा हूँ। आप इसे इतिहास से वापस पा सकते हैं।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pronto — tirando “%@” da sua lista. Dá para recuperar pelo histórico."
          }
        }
      }
    },
    "breakdown_msg_kept_reask": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kept it. So — what's stopping you from “%@”?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La conservamos. Entonces, ¿qué te impide avanzar con «%@»?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Behalten. Also — was hält dich bei „%@“ auf?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रख लिया। तो — “%@” में आपको क्या रोक रहा है?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantido. Então — o que está te impedindo de “%@”?"
          }
        }
      }
    },
    "breakdown_msg_added_to_plan": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
