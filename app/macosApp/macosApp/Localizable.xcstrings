    "activity_empty_body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every change you make — and every change synced from elsewhere — shows up here, newest first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada cambio que haces — y cada cambio sincronizado desde otro lugar — aparece aquí, del más reciente al más antiguo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jede Änderung, die du machst — und jede, die von woanders synchronisiert wird — erscheint hier, die neueste zuerst."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका किया हर बदलाव — और कहीं और से सिंक हुआ हर बदलाव — यहाँ दिखता है, सबसे नया सबसे ऊपर।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada alteração que você faz — e cada alteração sincronizada de outro lugar — aparece aqui, da mais recente para a mais antiga."
          }
        }
      }
    },
