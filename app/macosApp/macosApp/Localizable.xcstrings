    "breakdown_msg_added_prerequisite": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Added a prerequisite to do first: “%@”."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
