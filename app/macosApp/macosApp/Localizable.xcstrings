          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich habe eine Voraussetzung hinzugefügt, die zuerst drankommt: „%@“."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पहले करने के लिए एक ज़रूरी कदम जोड़ा: “%@”।"
          }
        },
        "pt": {
