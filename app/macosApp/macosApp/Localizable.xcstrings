          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सब हो गया — जो आपको ज़रूरी नहीं था, वह हमने हटा दिया।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
