    "breakdown_prereq_figure_out": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Figure out how to do this"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Averiguar cómo hacer esto"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Herausfinden, wie das geht"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "समझें कि इसे कैसे करना है"
