<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.circuitstitch.deferno.auth-redirect</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.circuitstitch.deferno</string>
			</array>
		</dict>
	</array>
	<key>LSMultipleInstancesProhibited</key>
	<true/>
	<!-- Dev-only: substituted from the DEV_STAGING_TOKEN build setting (Local.xcconfig ← Secrets.xcconfig,
	     emptied for Release in project.yml). DefernoRoot.seedDevAccounts() seeds a "Dev (staging)" account
	     from it on a Debug build; blank in any committed/Release build so no PAT ships. Mirrors app/iosApp. -->
	<key>DevStagingToken</key>
	<string>$(DEV_STAGING_TOKEN)</string>
</dict>
</plist>
