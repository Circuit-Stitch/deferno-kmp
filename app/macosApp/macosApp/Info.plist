<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!-- Merged into the generated Info.plist (GENERATE_INFOPLIST_FILE stays YES; explicit keys win) — the
     macOS twin of app/iosApp/iosApp/Info.plist. Holds only what the INFOPLIST_KEY_* build settings
     can't express: the custom URL scheme the OAuth redirect re-enters the app on (ADR-0026, #137),
     forwarded by DefernoApp.onOpenURL → DefernoRoot.forwardAuthRedirect. The real browser OAuth leg
     is #189; paste-PAT sign-in needs no redirect.

     Optional dev-PAT seeding (DefernoRoot.seedDevAccounts, ADR-0012): add `DevAccounts` +
     `DevStagingToken` string keys here LOCALLY to open on real staging data without typing — kept out
     of git (no PAT ships); absent → nothing is seeded. -->
<dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.circuitstitch.deferno.auth-redirect</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.circuitstitch.deferno</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
