# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java/Kotlin class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/

# Local configuration file (SDK path, etc.) — machine-specific, never commit
local.properties

# Log/OS files
*.log
.DS_Store

# Android Studio / IntelliJ
*.iml
.idea/*
# Keep a couple of shareable IDE settings if you choose to commit them later:
!.idea/codeStyles/
!.idea/inspectionProfiles/
!.idea/runConfigurations/
.idea/caches/
.idea/libraries/
.idea/modules.xml
.idea/workspace.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml
.idea/deploymentTargetSelector.xml
.idea/deploymentTargetDropDown.xml
.idea/misc.xml
captures/

# NDK
.externalNativeBuild/
.cxx/

# Xcode (iOS app — the .xcodeproj is created on macOS and may be committed; keep the
# user/machine-specific cruft out of it). See app/iosApp/README.md.
xcuserdata/
*.xcuserstate
DerivedData/

# Keystores and signing — never commit secrets
*.jks
*.keystore
keystore.properties

# Google Services / Firebase (often contains keys — opt in per-project)
# google-services.json

# Kotlin
.kotlin/

# Profiling
*.hprof

# On-device whisper model weights (#92, ADR-0019): ~190 MB, fetched into the Play Asset Delivery
# install-time pack by :speech-model-pack:downloadWhisperModel. Never committed (not self-hosted,
# not in git) — a clean checkout downloads it on first app build.
speech-model-pack/src/main/assets/models/
# Desktop whisper weights (#94, ADR-0019): ~190 MB, fetched into the Compose Desktop installer resources
# by :app:desktopApp:downloadWhisperModel. Never committed; the .gitkeep keeps the tree present.
app/desktopApp/desktopResources/common/models/*.bin
